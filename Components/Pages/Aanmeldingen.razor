@page "/admin/aanmeldingen"
@rendermode InteractiveServer
@using BlazorApp1.Models
@using BlazorApp1.Services
@inject AanmeldenService AanmeldenService

<PageTitle>Aanmeldingen Beheer</PageTitle>

<h1>Aanmeldingen Beheer</h1>

@if (aanmeldingen == null)
{
    <p>Loading...</p>
}
else
{
    <p>Found @aanmeldingen.Count records.</p>
    <ul>
        @foreach (var item in aanmeldingen)
        {
            <li>@item.Naam - @item.Email</li>
        }
    </ul>
}

@code {
    private List<AanmeldenModel> aanmeldingen = new();

    protected override async Task OnInitializedAsync()
    {
        try
        {
            aanmeldingen = await AanmeldenService.GetAllAanmeldingenAsync();
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Error: {ex.Message}");
        }
    }
}