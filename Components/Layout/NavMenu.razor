<style>

    nav {
        width: 100%;
        background-color: #E3F2FD;
        box-shadow: 0 8px 25px rgba(0, 0, 0, 0.12);
        position: sticky;
        top: 0;
        z-index: 1000;
        border-bottom: 1px solid rgba(30, 136, 229, 0.15);
    }


    .nav-container {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 20px;

        display: flex;
        align-items: center;
        justify-content: space-between;
    }


    /* Logo */

    .logo-link {
        display: block;
        padding: 10px 0;
    }


    .logo {
        height: 70px;
        width: auto;
        max-width: 180px;
        display: block;
    }


    /* Desktop menu */

    ul {
        list-style: none;
        display: flex;
        align-items: center;
        gap: 10px;

        margin: 0;
        padding: 0;
    }


    li {
        margin: 0;
    }


    ul li a {
        display: block;

        color: #1E3A8A;

        padding: 12px 18px;

        text-decoration: none;

        font-weight: 500;

        border-radius: 30px;

        transition: all 0.3s ease;
    }


    ul li a:hover {
        background-color: rgba(30, 136, 229, 0.12);
        color: #0D47A1;
    }


    ul li a.active {
        background-color: rgba(13, 71, 161, 0.18);
        color: #0D47A1;
        font-weight: 600;

        box-shadow: 0 3px 8px rgba(13, 71, 161, 0.15);
    }


    /* Mobile hamburger */

    .menu-toggle {
        display: none;

        background: transparent;

        border: none;

        color: #1E3A8A;

        font-size: 32px;

        cursor: pointer;

        padding: 5px;
    }



    /* Mobile layout */

    .media (max-width: 768px) {


        .logo {
            height: 55px;
        }


        .menu-toggle {
            display: block;
        }


        ul {

            position: absolute;

            top: 100%;

            left: 0;

            width: 100%;


            flex-direction: column;

            background-color: #E3F2FD;


            display: none;


            padding: 20px 0;


            box-shadow: 0 8px 20px rgba(0,0,0,0.12);

        }


        ul.open {
            display: flex;
        }


        ul li {
            width: 100%;
            text-align: center;
        }


        ul li a {

            padding: 14px 20px;

            width: 100%;

        }

    }

</style>


@code {

    private bool _menuOpen;


    private void ToggleMenu()
    {
        _menuOpen = !_menuOpen;
    }


    private void CloseMenu()
    {
        _menuOpen = false;
    }

}